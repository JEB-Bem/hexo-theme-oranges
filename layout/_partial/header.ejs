<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="author" content="<%= config.author %>" />
  <% 
  var metaDescription = page.description || config.description;
  var ogDescription = page.ogdescription || page.description || config.description;
  var metaKeywords = page.keywords || config.keywords;
  var pageStyles = [];

  if (Array.isArray(metaKeywords)) {
    metaKeywords = metaKeywords.join(', ');
  }

  if (is_home()) {
    pageStyles.push('home');
  }

  if (is_tag() || is_category() || page.type === 'tags' || page.type === 'categories') {
    pageStyles.push('taxonomy');
  }

  if (is_archive() || is_tag()) {
    pageStyles.push('posts');
  }

  if (is_archive()) {
    pageStyles.push('archive');
  }

  if (page.type === 'about') {
    pageStyles.push('about');
  }

  if (page.type === 'friends') {
    pageStyles.push('friends');
  }

  if (page.type === 'tools') {
    pageStyles.push('tools');
  }

  if (page.type === 'favorites') {
    pageStyles.push('favorites');
  }

  if (page.type === 'posts') {
    pageStyles.push('posts');
  }

  if (!is_home() && !is_archive() && !is_tag() && !is_category() && !page.type) {
    pageStyles.push('post-detail');
  }
  %>

  <% if (metaDescription) { %>
    <meta name="description" content="<%= metaDescription %>" />
  <% } %>

  <% if (metaKeywords) { %>
    <meta name="keywords" content="<%= metaKeywords %>" />
  <% } %>

  <% if (ogDescription) { %>
    <meta property="og:description" content="<%= ogDescription %>" />
  <% } %>

  <% if (is_home() && page.current > 1) { %>
    <meta name="robots" content="noindex" />
  <% } %>
  <%
    var titleText = page.title;

    if (is_archive()) {
      if (is_month()) {
        titleText = __('archive_b', page.year + '/' + page.month);
      } else if (is_year()) {
        titleText = __('archive_b', page.year);
      } else {
        titleText = __('archive_a');
      }
    } else if (is_category()) {
      titleText = __('category') + ' : ' + page.category;
    } else if (is_tag()) {
      titleText = __('tag') + ' : ' + page.tag;
    } else {
      var pageTypeTitleMap = {
        friends: 'friend',
        categories: 'categories',
        tags: 'tags',
        about: 'about',
        presentations: 'presentations',
        tools: 'tools',
        favorites: 'Favorites',
        posts: 'Posts'
      };

      var pageTitleKey = pageTypeTitleMap[page.type] || pageTypeTitleMap[page.title];
      if (pageTitleKey) {
        titleText = __(pageTitleKey);
      }
    }
  %>
  <title>
    <% if (titleText) { %>
      <%= titleText %>
      |
    <% } %>
     <%= config.title %>
  </title>

  <% if (theme.favicon.enable){ %>
    <link rel="apple-touch-icon" href="<%- theme.favicon.touch_icon %>">
    <link rel="icon" href="<%- theme.favicon.icon %>">
  <% } %>

  <!-- Raleway-Font -->
  <link href="https://fonts.googleapis.com/css?family=Raleway&display=swap" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/satoshi" rel="stylesheet">

  <!-- hexo site css -->
  <link rel="stylesheet" href="/css/main.css" />
  <% pageStyles.forEach(function(styleName) { %>
    <link rel="stylesheet" href="/css/pages/<%= styleName %>.css" />
  <% }) %>
  <link rel="stylesheet" href="//at.alicdn.com/t/font_1886449_67xjft27j1l.css" />

  <!-- katex -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex/dist/katex.min.css"
  />

  <!-- jquery3.3.1 -->
  <% if (theme.cdns && theme.cdns.jquery && theme.cdns.jquery.enable) { %>
    <script defer type="text/javascript" src="<%- theme.cdns.jquery.url %>"></script>
  <% } else { %>
    <script defer type="text/javascript" src="/plugins/jquery.min.js"></script>
  <% } %>

  <!-- fancybox -->
  <% if (theme.cdns && theme.cdns.fancybox && theme.cdns.fancybox.enable) { %>
    <link href="<%- theme.cdns.fancybox.url.css %>" rel="stylesheet">
    <script defer type="text/javascript" src="<%- theme.cdns.fancybox.url.js %>"></script>
  <% } else { %>
    <link href="/plugins/jquery.fancybox.min.css" rel="stylesheet">
    <script defer type="text/javascript" src="/plugins/jquery.fancybox.min.js"></script>
  <% } %>
  <%- js(['/js/fancybox.js']) %>
  <%- js(['/js/shiki-copy.js']) %>

  <% if(theme.gtag.enable) { %>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%- theme.gtag.gtagkey %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%- theme.gtag.gtagkey %>');
    </script>
  <% } %>

  <% if(theme.baidu_s.enable) { %>
    <meta name="baidu-site-verification" content="<%= theme.baidu_s.key %>" />
  <% } %>

  <% if (theme.footer.views && theme.footer.views.enable) { %>
    <script async src="<%- theme.footer.views.provider %>"></script>
  <% } %>

  <script>
    (function() {
      var html = document.documentElement
      var storedMode = localStorage.getItem('color-mode')
      var mediaQuery = window.matchMedia('(prefers-color-scheme: dark)')
      var resolvedMode = storedMode && storedMode !== 'auto'
        ? storedMode
        : (mediaQuery.matches ? 'dark' : 'light')

      html.setAttribute('color-mode', resolvedMode)
      window.__themePreference = storedMode || 'auto'
      window.__colorMode = resolvedMode
      window.__giscusTheme = resolvedMode === 'dark' ? 'noborder_gray' : 'light'
    })()
  </script>
</head>
