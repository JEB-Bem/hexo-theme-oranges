<%
  const toolsHero = (toolsPage && toolsPage.hero) || {}
  const toolSections = (toolsPage && toolsPage.sections) || []
  const cardClasses = ['tool-card-blue', 'tool-card-cyan', 'tool-card-ice', 'tool-card-deep', 'tool-card-sky', 'tool-card-steel']
%>

<div class="tools-shell">
  <section class="tools-hero">
    <% if (toolsHero.title) { %>
      <h2><%- toolsHero.title %></h2>
    <% } %>
    <% if (toolsHero.lead) { %>
      <p class="tools-lead"><%- toolsHero.lead %></p>
    <% } %>
    <% if (toolsHero.eyebrow) { %>
      <p class="tools-eyebrow"><%- toolsHero.eyebrow %></p>
    <% } %>
  </section>

  <% toolSections.forEach(function(section, sectionIndex) { %>
    <section class="tools-section">
      <div class="tools-section-head">
        <h3><%- section.title %></h3>
        <% if (section.description) { %>
          <p><%- section.description %></p>
        <% } %>
      </div>

      <div class="tools-grid">
        <% (section.items || []).forEach(function(item, itemIndex) { %>
          <%
            const toolIndex = sectionIndex * 12 + itemIndex
            const toolClass = cardClasses[toolIndex % cardClasses.length]
            const toolInitial = item.title ? item.title.trim().charAt(0).toUpperCase() : '?'
            const toolDelay = (0.05 + toolIndex * 0.07).toFixed(2) + 's'
          %>
          <a class="tool-card <%- toolClass %>" style="--card-delay: <%- toolDelay %>" href="<%- item.url %>" target="_blank" rel="noopener noreferrer">
            <span class="tool-card-badge">
              <% if (item.favicon) { %>
                <img src="<%- item.favicon %>" alt="<%- item.title %> favicon" loading="lazy">
              <% } else { %>
                <span class="tool-card-badge-fallback"><%- toolInitial %></span>
              <% } %>
            </span>
            <div class="tool-card-body">
              <% if (item.label) { %>
                <div class="tool-card-meta"><%- item.label %></div>
              <% } %>
              <div class="tool-card-title"><%- item.title %></div>
              <% if (item.description) { %>
                <p class="tool-card-desc"><%- item.description %></p>
              <% } %>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  <% }) %>
</div>
