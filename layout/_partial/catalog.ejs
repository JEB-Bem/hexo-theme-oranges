<% if (theme.catalog.enable && (toc(page.content) || toc(page.origin))) { %>
  <aside class="post-catalog" id="catalog">
    <div class="post-catalog__head">
      <div class="title"><%= __('catalog') %></div>
      <button
        id="btn-catalog"
        class="btn-catalog"
        type="button"
        aria-controls="catalog"
        aria-expanded="true"
        aria-label="<%= __('catalog') %>"
      >
        <span id="btn-catalog-icon" class="btn-catalog__arrow" aria-hidden="true"></span>
      </button>
    </div>
    <div class="catalog-content">
      <% if (page.encrypt == true) { %>
        <%- toc(page.origin, { "list_number": false }) %>
      <% } else { %>
        <%- toc(page.content, { "list_number": false }) %>
      <% } %>
    </div>
  </aside>

  <%- js(['/js/catalog.js']) %>

<% } %>
