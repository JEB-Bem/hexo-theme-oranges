<!-- 文章详情页，展示文章具体内容，url形式：https://yoursite/文章标题/ -->
<!-- 同时为「标签tag」，「朋友friend」，「分类categories」，「关于about」页面的承载页面，具体展示取决于page.type -->

<% if (theme.mathjax && theme.mathjax.enable){ %>
  <%- partial('_partial/mathjax') %>
<% } %>

<%
  var pageTypeTitles = {
    about: __('about'),
    friends: __('friend'),
    presentations: __('presentations'),
    tools: __('tools'),
    favorites: 'Favorites',
    posts: 'Posts'
  }
%>

<% if (page.type === "tags") { %>
  <!-- 标签页 url形式：https://yoursite/tags/ -->
  <div class="container tag-index">
    <div>
      <%- list_tags({ class: "tag" }) %>
    </div>
  </div>
  <% } %>

  <% if (page.type === "categories") { %>
  <!-- 分类页 url形式：https://yoursite/categories/ -->
  <div class="container category-index">
    <div>
      <%- list_categories({orderby: "length", order: -1}) %>
    </div>
  </div>
  <% } %>

  <% if (page.type === "friends") { %>
  <!-- 朋友页 url形式：https://yoursite/friends/ -->
  <div class="container friend-index">
    <div class="friend-section">
      <h2 class="friend-section-title">活跃链接</h2>
      <div class="friend-list">
        <% for(let friend of theme.friends) { %>
          <% 
            let friendName = friend.name || friend.nickname
            let friendDesc = friend.description || friend.meta
            let friendAvatar = friend.avatar
            let friendInitial = friendName ? friendName.trim().charAt(0).toUpperCase() : "?"
          %>
          <a class="friend-card" href="<%- friend.site %>" target="_blank" rel="noopener noreferrer">
            <div class="friend-card-avatar">
              <% if (friendAvatar) { %>
                <img src="<%- friendAvatar %>" alt="<%- friendName %> avatar" loading="lazy">
              <% } else { %>
                <span class="friend-card-avatar-fallback"><%- friendInitial %></span>
              <% } %>
            </div>
            <div class="friend-card-body">
              <div class="friend-card-name"><%- friendName %></div>
              <% if (friendDesc) { %>
                <p class="friend-card-desc"><%- friendDesc %></p>
              <% } %>
            </div>
          </a>
        <% } %>
      </div>
    </div>
    <% if (theme.inactive_friends && theme.inactive_friends.length > 0) { %>
      <div class="friend-section friend-section-inactive">
        <h2 class="friend-section-title"><%= __('inactive_friends') %></h2>
        <div class="friend-list">
          <% for(let friend of theme.inactive_friends) { %>
            <% 
              let friendName = friend.name || friend.nickname
              let friendDesc = friend.description || friend.meta
              let friendAvatar = friend.avatar
              let friendInitial = friendName ? friendName.trim().charAt(0).toUpperCase() : "?"
            %>
            <a class="friend-card" href="<%- friend.site %>" target="_blank" rel="noopener noreferrer">
              <div class="friend-card-avatar">
                <% if (friendAvatar) { %>
                  <img src="<%- friendAvatar %>" alt="<%- friendName %> avatar" loading="lazy">
                <% } else { %>
                  <span class="friend-card-avatar-fallback"><%- friendInitial %></span>
                <% } %>
              </div>
              <div class="friend-card-body">
                <div class="friend-card-name"><%- friendName %></div>
                <% if (friendDesc) { %>
                  <p class="friend-card-desc"><%- friendDesc %></p>
                <% } %>
              </div>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
    <div class="markdown-body">
      <%- page.content %>
    </div>
  </div>
  <% } %>

  <% if(page.type === "about") { %>
  <!-- 关于页 url形式：https://yoursite/about/ -->
    <div class="container about-index">
      <div class="markdown-body">
        <%- page.content %>
      </div>
    </div>
  <% } %>

  <% if(page.type === "presentations") { %>
  <!-- 演示页 url形式：https://yoursite/presentations/ -->
    <div class="container presentations-index">
      <div class="markdown-body">
        <%- page.content %>
      </div>
    </div>
  <% } %>

  <% if(page.type === "tools") { %>
  <!-- 工具页 url形式：https://yoursite/tools/ -->
    <div class="container tools-index">
      <div class="tools-content">
        <%- partial('_partial/tools-page', { toolsPage: site.data.tools || {} }) %>
      </div>
    </div>
  <% } %>

  <% if(page.type === "favorites") { %>
  <% var favoritesData = (site.data && site.data.favorites) || {}; %>
  <% var favoriteItems = favoritesData.items || []; %>
    <div class="container collection-index">
      <div class="collection-shell">
        <section class="collection-hero">
          <p class="collection-eyebrow">Curated Reading</p>
          <div class="collection-heading">
            <h1>Favorites</h1>
            <p><%- favoritesData.description || '这是一些我觉得有深度，或者足够有趣、值得反复回看的文章' %></p>
          </div>
          <div class="collection-meta">
            <span><%= favoriteItems.length %> picks</span>
          </div>
        </section>
        <section class="collection-list" aria-label="Favorite articles">
          <% favoriteItems.forEach(function(item, index) { %>
            <article class="collection-item">
              <span class="collection-item-index"><%= String(index + 1).padStart(2, '0') %></span>
              <a class="collection-item-link" href="<%- url_for(item.path) %>">
                <span class="collection-item-title"><%- item.title %></span>
              </a>
            </article>
          <% }) %>
        </section>
      </div>
    </div>
  <% } %>

  <% if(page.type === "posts") { %>
    <%
      var currentPageNum = page.current;
      var pageMax = config.per_page || 10;
      var totalPosts = site.posts.length;
      var postsToShow = Array.isArray(page.posts) ? page.posts : page.posts.toArray();
      var showingCount = postsToShow.length;
    %>
    <div class="container posts-index">
      <div class="posts-shell">
        <main class="posts-main">
          <div class="posts-heading">
            <h1>Posts</h1>
          </div>
          <div class="posts-toolbar">
            <div class="posts-toolbar-summary">
              Page <%= currentPageNum %> - Showing <%= showingCount %> of <%= totalPosts %>
            </div>
            <a class="posts-toolbar-link" href="<%- url_for('/archives/') %>">Archives &rarr;</a>
          </div>
          <div class="posts-card-list">
            <% postsToShow.forEach(function(item) { %>
              <%
                var itemDescription = item.description || '';
                if (!itemDescription && item.excerpt) {
                  itemDescription = item.excerpt.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
                }
                var itemCategories = (item.categories && item.categories.data) || [];
                var itemTags = (item.tags && item.tags.data) || [];
              %>
              <article class="posts-card<%= item.top ? ' is-top' : '' %>" title="<%- item.title %>">
                <div class="posts-card-date"><%- item.date.format("MMM DD, YYYY") %></div>
                <a class="posts-card-title-link" href="<%- url_for(item.path) %>">
                  <div class="posts-card-title"><%- item.title || 'untitled' %></div>
                </a>
                <% if (itemDescription) { %>
                  <p class="posts-card-description"><%- itemDescription %></p>
                <% } %>
                <div class="posts-card-meta">
                  <% if (itemCategories.length > 0) { %>
                    <div class="posts-card-group">
                      <span class="posts-card-label">Category</span>
                      <div class="posts-card-chips">
                        <% itemCategories.forEach(function(category) { %>
                          <a class="posts-chip posts-chip-category" href="<%- url_for(category.path) %>"><%- category.name %></a>
                        <% }) %>
                      </div>
                    </div>
                  <% } %>
                  <% if (itemTags.length > 0) { %>
                    <div class="posts-card-group">
                      <span class="posts-card-label">Tags</span>
                      <div class="posts-card-chips">
                        <% itemTags.forEach(function(tag) { %>
                          <a class="posts-chip" href="<%- url_for(tag.path) %>"><%- tag.name %></a>
                        <% }) %>
                      </div>
                    </div>
                  <% } %>
                </div>
                <a class="posts-card-arrow" href="<%- url_for(item.path) %>" aria-label="<%- item.title || 'untitled' %>"></a>
              </article>
            <% }) %>
          </div>
          <div class="posts-pagination">
            <% if (page.prev !== 0) { %>
              <a class="posts-pagination-link" href="<%- url_for(page.prev_link) %>">&larr; Previous Posts</a>
            <% } else { %>
              <span class="posts-pagination-link is-disabled">&larr; Previous Posts</span>
            <% } %>
            <% if (page.next !== 0) { %>
              <a class="posts-pagination-link" href="<%- url_for(page.next_link) %>">Next Posts &rarr;</a>
            <% } else { %>
              <span class="posts-pagination-link is-disabled">Next Posts &rarr;</span>
            <% } %>
          </div>
        </main>
        <div class="posts-sidebar">
          <div class="posts-sidebar-sticky">
            <div class="posts-sidebar-title">Tags</div>
              <div class="posts-sidebar-tags">
                <% site.tags.sort('name', 1).each(function(tag) { %>
                  <a class="posts-sidebar-tag" href="<%- url_for(tag.path) %>">
                    <span><%- tag.name %></span>
                  </a>
                <% }) %>
              </div>
            </div>
        </div>
      </div>
    </div>
  <% } %>

  <% if (!page.type) { %>
  <!-- 文章内容页 url形式：https://yoursite/文章标题/ -->
  <div class="container post-details" id="post-details">
    <div class="post-content">
      <h1 class="post-title"><%- page.title %></h1>
      <div class="post-attach">
        <span class="post-pubtime">
          <i class="iconfont icon-updatetime mr-10" title="<%= __('updateTime') %>"></i>
          <%- page.updated.format("YYYY-MM-DD HH:mm:ss") %>
        </span>
        <!-- 不显示文章前的标签等信息
        <% for(item of theme.navbar) {
          if (item.key === 'tags' && item.enable) {
            if(page.tags && page.tags.length > 0) { %>
              <span class="post-tags">
                <i class="iconfont icon-tags mr-10" title="<%= __('tags') %>"></i>
                <% for(let item of page.tags.data) { %>
                <span class="span--tag mr-8">
                  <a href="<%= url_for(item.path)%>" title="<%- item.name %>">
                    #<%- item.name %>
                  </a>
                </span>
                <% } %>
              </span>
          <% }
          }
          if (item.key === 'categories' && item.enable) {
            if(page.tags && page.categories.length > 0) { %>
              <span class="post-categories">
                <i class="iconfont icon-bookmark" title="<%= __('categories') %>"></i>
                <% for(let item of page.categories.data){ %>
                <span class="span--category">
                  <a href="<%= url_for(item.path)%>" title="<%- item.name %>">
                    <b>#</b> <%- item.name %>
                  </a>
                </span>
                <% } %>
              </span>
          <% }
          }
        } %>
        -->
      </div>
      <div class="markdown-body">
        <%- page.content %>
      </div>
      <div class="github-edit">
          <% if(page.github) { %>
              <a class="github-edit-link" href="<%= page.github %>">
          <% } else { %>
              <a class="github-edit-link" href="https://github.com/JEB-Bem/JBlog/blob/master/source/_posts/<%= page.filename %>">
          <% }%>
          <svg t="1762006383543" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="4646" width="25" height="25"><path d="M928 365.664a32 32 0 0 0-32 32V864a32 32 0 0 1-32 32H160a32 32 0 0 1-32-32V160a32 32 0 0 1 32-32h429.6a32 32 0 0 0 0-64H160a96 96 0 0 0-96 96v704a96 96 0 0 0 96 96h704a96 96 0 0 0 96-96V397.664a32 32 0 0 0-32-32z" fill="#4aa7f7" p-id="4647"></path><path d="M231.616 696.416a38.4 38.4 0 0 0 44.256 53.792l148-38.368L950.496 185.248 814.72 49.472 290.432 573.76l-58.816 122.656z m111.808-85.12L814.72 140l45.248 45.248-468.992 468.992-77.824 20.16 30.272-63.104z" fill="#4aa7f7" p-id="4648"></path></svg>
          &nbsp在 Github 上编辑此页
          </a>
          <button class="post-print-action" type="button" onclick="handleArticlePrint()">
            打印本文
          </button>
      </div>
      <script>
        (function () {
          var detailsState = null
          var themeState = null

          function setAllDetailsOpen() {
            var details = Array.prototype.slice.call(document.querySelectorAll('.post-content details'))
            detailsState = details.map(function (node) {
              return node.hasAttribute('open')
            })
            details.forEach(function (node) {
              node.open = true
            })
          }

          function restoreDetailsState() {
            if (!detailsState) {
              return
            }
            var details = document.querySelectorAll('.post-content details')
            details.forEach(function (node, index) {
              if (detailsState[index]) {
                node.open = true
              } else {
                node.open = false
                node.removeAttribute('open')
              }
            })
            detailsState = null
          }

          function setPrintThemeLight() {
            if (themeState) {
              return
            }
            themeState = {
              preference: window.__themePreference || localStorage.getItem('color-mode') || 'auto',
              colorMode: document.documentElement.getAttribute('color-mode') || 'light'
            }

            if (typeof window.applyThemeMode === 'function') {
              window.applyThemeMode('light')
              return
            }

            document.documentElement.setAttribute('color-mode', 'light')
          }

          function restoreThemeState() {
            if (!themeState) {
              return
            }

            if (typeof window.applyThemeMode === 'function') {
              window.applyThemeMode(themeState.preference || 'auto')
            } else {
              document.documentElement.setAttribute('color-mode', themeState.colorMode || 'light')
            }

            themeState = null
          }

          window.handleArticlePrint = function () {
            setAllDetailsOpen()
            setPrintThemeLight()
            window.print()
          }

          window.addEventListener('beforeprint', function () {
            setAllDetailsOpen()
            setPrintThemeLight()
          })
          window.addEventListener('afterprint', function () {
            restoreDetailsState()
            restoreThemeState()
          })
        })()
      </script>
      <% if(theme.prevnext.enable) { %>
        <div class="prev-or-next">
          <div class="post-foot-next">
            <% if(page.next) { %>
              <a href="<%- url_for(page.next.path) %>" target="_self">
                <i class="iconfont icon-chevronleft"></i>
                <span><%= __('prev') %></span>
              </a>
            <% } %>
          </div>
          <div class="post-attach">
            <span class="post-pubtime">
              <i class="iconfont icon-updatetime mr-10" title="<%= __('updateTime') %>"></i>
              <%- page.updated.format("YYYY-MM-DD HH:mm:ss") %>
            </span>
            <% for(item of theme.navbar) {
              if (item.key === 'tags' && item.enable) {
                if(page.tags && page.tags.length > 0) { %>
                  <span class="post-tags">
                    <i class="iconfont icon-tags mr-10" title="<%= __('tags') %>"></i>
                    <% for(let item of page.tags.data) { %>
                    <span class="span--tag mr-8">
                      <a href="<%= url_for(item.path)%>" title="<%- item.name %>">
                        #<%- item.name %>
                      </a>
                    </span>
                    <% } %>
                  </span>
              <% }
              }
              if (item.key === 'categories' && item.enable) {
                if(page.tags && page.categories.length > 0) { %>
                  <span class="post-categories">
                    <i class="iconfont icon-bookmark" title="<%= __('categories') %>"></i>
                    <% for(let item of page.categories.data){ %>
                    <span class="span--category">
                      <a href="<%= url_for(item.path)%>" title="<%- item.name %>">
                        <b>#</b> <%- item.name %>
                      </a>
                    </span>
                    <% } %>
                  </span>
              <% }
              }
            } %>
          </div>
          <div class="post-foot-prev">
            <% if(page.prev) { %>
              <a href="<%- url_for(page.prev.path) %>" target="_self">
                <span><%= __('next') %></span>
                <i class="iconfont icon-chevronright"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
    <%- partial("_partial/catalog") %>
    <% if(theme.giscus && theme.giscus.enable) { %>
      <div class="comments-container">
        <%- partial("_partial/giscus") %>
      </div>
    <% } %>
  </div>
<% } %>
