@import 'github-markdown.css'
@import 'color-scheme.css'
@import 'base.css'
@import '_common/layout'
@import '_common/utils'
@import '_common/components'

$theme-color = convert(hexo-config('themeColor'))

:root[color-mode="light"]
  --theme-accent $theme-color
  --theme-accent-soft rgba($theme-color, 0.12)
  --theme-accent-softer rgba($theme-color, 0.06)
  --theme-accent-border rgba($theme-color, 0.22)
  --theme-accent-strong rgba($theme-color, 0.42)
  --theme-accent-shadow rgba($theme-color, 0.14)
  --theme-accent-text mix(#3f70b5, $theme-color, 55%)

:root[color-mode="dark"]
  --theme-accent $theme-color
  --theme-accent-soft rgba($theme-color, 0.18)
  --theme-accent-softer rgba($theme-color, 0.1)
  --theme-accent-border rgba($theme-color, 0.28)
  --theme-accent-strong rgba($theme-color, 0.5)
  --theme-accent-shadow rgba($theme-color, 0.22)
  --theme-accent-text mix(#cfe6ff, $theme-color, 38%)

.markdown-body {
  code {
    color: var(--color-text-md-code);
  }
  a {
    &:hover {
      border-bottom: 2px solid $theme-color;
    }
  }
  b {
    color: #5d8ab6;
  }
  blockquote {
    border-color: var(--color-block-md-quote);
  }
}

.navbar {
  ul {
    li {
      a {
        &:hover {
          &::after {
            background-color: $theme-color;
          }
        }
      }
      &.active {
        a {
          &::after {
            background-color: $theme-color;
          }
        }
      }
    }
  }
}

.markdown-body h1 .headerlink::before,
.markdown-body h2 .headerlink::before,
.markdown-body h3 .headerlink::before,
.markdown-body h4 .headerlink::before,
.markdown-body h5 .headerlink::before,
.markdown-body h6 .headerlink::before {
  color: $theme-color;
}

/* Keep normal code blocks readable; plain text blocks opt into tighter spacing separately. */
.markdown-body pre,
.markdown-body .highlight pre,
.article-entry pre,
.article-entry .highlight,
.article-entry .highlight pre {
  line-height: 1.5;
}

.markdown-body pre code,
.markdown-body .highlight code,
.article-entry pre code,
.article-entry .highlight code,
.article-entry .highlight .line {
  line-height: inherit;
}

.article-entry .highlight .line {
  height: auto;
}
